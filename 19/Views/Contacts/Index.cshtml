@model List<PhoneBook.Models.Contact>

@{
    ViewData["Title"] = "Телефонный справочник";
}

<div class="container mt-4">
    <h2>📞 Телефонный справочник</h2>

    <form method="get" action="/Contacts/Search" class="mb-3">
        <div class="input-group">
            <input type="text" name="name" class="form-control"
                   placeholder="Поиск по имени..." />
            <button class="btn btn-primary" type="submit">🔍 Найти</button>
        </div>
    </form>

    <a asp-action="Add" asp-controller="Contacts"
       class="btn btn-success mb-3">➕ Добавить контакт</a>

    @if (Model.Any())
    {
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Email</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contact in Model)
                {
                    <tr>
                        <td>@contact.Id</td>
                        <td>@contact.Name</td>
                        <td>@contact.PhoneNumber</td>
                        <td>@contact.Email</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">Контактов пока нет.</div>
    }
</div>