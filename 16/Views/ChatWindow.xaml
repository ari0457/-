<Window x:Class="HotelBookingApp.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат с администрацией"
        Height="480" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
            </Border.Effect>
            <ListBox ItemsSource="{Binding Messages}"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="13" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Отправить"
                    Command="{Binding SendCommand}"
                    Background="#1A3C5E" Foreground="White"
                    Padding="14,8" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D2A45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>