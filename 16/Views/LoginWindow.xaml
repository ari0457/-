<Window x:Class="HotelBookingApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход — Grand Palace Hotel"
        Height="440" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F4F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Margin="24" Background="White" CornerRadius="12" Padding="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.1"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="🏨" FontSize="36" HorizontalAlignment="Center"/>
            <TextBlock Text="Grand Palace Hotel" FontSize="18" FontWeight="Bold"
                       Foreground="#1A3C5E" HorizontalAlignment="Center" Margin="0,6,0,20"/>

            <!-- ФИО только при регистрации -->
            <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="ФИО:" FontSize="12" Foreground="#5A6A7E" Margin="0,0,0,4"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" FontSize="13" Margin="0,0,0,12"/>
            </StackPanel>

            <TextBlock Text="Логин:" FontSize="12" Foreground="#5A6A7E" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,12"/>

            <TextBlock Text="Пароль:" FontSize="12" Foreground="#5A6A7E" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdBox" Padding="8,6" FontSize="13" Margin="0,0,0,16"
                         PasswordChanged="PwdBox_PasswordChanged"/>

            <!-- Ошибка -->
            <Border Background="#FFF3CD" CornerRadius="6" Padding="10,6" Margin="0,0,0,12"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Foreground="#856404" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Кнопка Войти (видна в режиме входа) -->
            <Button Content="Войти" Command="{Binding LoginCommand}"
                    Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}"
                    Background="#1A3C5E" Foreground="White" FontSize="14"
                    FontWeight="SemiBold" Padding="0,10" BorderThickness="0"
                    Cursor="Hand" Margin="0,0,0,8">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D2A45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Кнопка Зарегистрироваться (видна в режиме регистрации) -->
            <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}"
                    Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}"
                    Background="#2E7D32" Foreground="White" FontSize="14"
                    FontWeight="SemiBold" Padding="0,10" BorderThickness="0"
                    Cursor="Hand" Margin="0,0,0,8">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Переключение режима -->
            <Button Command="{Binding SwitchModeCommand}"
                    Background="Transparent" Foreground="#1A3C5E"
                    FontSize="12" BorderThickness="0" Cursor="Hand" Padding="0,6">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Нет аккаунта? Зарегистрироваться"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                <Setter Property="Content" Value="Уже есть аккаунт? Войти"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>