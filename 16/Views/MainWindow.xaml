<Window x:Class="HotelBookingApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HotelBookingApp.ViewModels"
        Title="Система бронирования отеля"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="BookBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2E7D32"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter Property="Opacity"  Value="0.45"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button" BasedOn="{StaticResource BookBtn}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="20"/>
            <Setter Property="Margin"       Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="6,6,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏨" FontSize="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Grand Palace Hotel"
                                   FontSize="22" FontWeight="Bold" Foreground="#1A3C5E"/>
                        <TextBlock Text="{Binding CurrentUserDisplay, Mode=OneWay}"
                                   FontSize="12" Foreground="#5A6A7E"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Уведомление MMF -->
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="10,6" Margin="0,0,10,0"
                            Visibility="{Binding HasNotification, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding NotificationMessage, Mode=OneWay}"
                                   Foreground="#2E7D32" FontSize="12"
                                   MaxWidth="300" TextWrapping="Wrap"/>
                    </Border>
                    <Button Content="💬 Чат" Command="{Binding OpenChatCommand}"
                            Background="#1A3C5E" Margin="0,0,8,0"
                            Style="{StaticResource IconBtn}"/>
                    <Button Content="🚪 Выйти" Command="{Binding LogoutCommand}"
                            Background="#C62828"
                            Style="{StaticResource IconBtn}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНАЯ ОБЛАСТЬ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ КОЛОНКА -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Список номеров -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="🛏 Номера отеля"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#1A3C5E" Margin="0,0,0,12"/>
                        <ListView ItemsSource="{Binding Rooms}"
                                  SelectedItem="{Binding SelectedRoom}"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding"    Value="0"/>
                                    <Setter Property="Margin"     Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Margin="0,3" Padding="12,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#EBF8F1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                        <Setter Property="Background" Value="#FDE8E8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontWeight="Bold" FontSize="14" Foreground="#1A3C5E">
                                                        <Run Text="№"/><Run Text="{Binding RoomNumber, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Text=" — " Foreground="#5A6A7E"/>
                                                    <TextBlock Text="{Binding RoomType, Mode=OneWay}"
                                                               FontWeight="SemiBold" Foreground="#C9A84C"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description, Mode=OneWay}"
                                                           FontSize="11" Foreground="#5A6A7E"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock HorizontalAlignment="Right"
                                                           FontWeight="Bold" FontSize="13">
                                                    <Run Text="{Binding PricePerNight, Mode=OneWay, StringFormat={}{0:N0}}"/>
                                                    <Run Text=" ₽/н"/>
                                                </TextBlock>
                                                <TextBlock HorizontalAlignment="Right"
                                                           FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text"       Value="✅ Свободен"/>
                                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                    <Setter Property="Text"       Value="🔴 Занят"/>
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </Border>

                <!-- Форма бронирования -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📋 Новое бронирование"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#1A3C5E" Margin="0,0,0,12"/>

                        <TextBlock Text="ФИО гостя:" FontSize="12"
                                   Foreground="#5A6A7E" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding GuestName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="Дата заезда:" FontSize="12"
                                           Foreground="#5A6A7E" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding CheckIn}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="Дата выезда:" FontSize="12"
                                           Foreground="#5A6A7E" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding CheckOut}"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#FFF3CD" CornerRadius="6" Padding="10,6"
                                Margin="0,0,0,10"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ValidationError, Mode=OneWay}"
                                       Foreground="#856404" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="🛎 Забронировать"
                                Command="{Binding BookCommand}"
                                Style="{StaticResource BookBtn}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ПРАВАЯ КОЛОНКА -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="📂 Активные бронирования"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#1A3C5E" Margin="0,0,0,12"/>

                    <Button DockPanel.Dock="Bottom"
                            Content="🗑 Отменить выбранное бронирование"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CancelBtn}"
                            Margin="0,10,0,0"/>

                    <TextBlock Text="Нет активных бронирований."
                               Foreground="#5A6A7E" FontStyle="Italic"
                               TextWrapping="Wrap" Margin="0,0,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Bookings.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ListView ItemsSource="{Binding Bookings}"
                              SelectedItem="{Binding SelectedBooking}"
                              BorderThickness="0" Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding"    Value="0"/>
                                <Setter Property="Margin"     Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="14,10"
                                        Margin="0,4" Background="#F0F8FF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontWeight="Bold" FontSize="14" Foreground="#1A3C5E">
                                                    <Run Text="Бронь #"/>
                                                    <Run Text="{Binding Id, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Text=" — Номер " Foreground="#5A6A7E"/>
                                                <TextBlock Text="{Binding RoomNumber, Mode=OneWay}"
                                                           FontWeight="SemiBold" Foreground="#C9A84C"/>
                                            </StackPanel>
                                            <TextBlock Margin="0,4,0,0">
                                                <Run Text="👤 "/>
                                                <Run Text="{Binding GuestName, Mode=OneWay}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                            <TextBlock Foreground="#5A6A7E" FontSize="12" Margin="0,2,0,0">
                                                <Run Text="📅 "/>
                                                <Run Text="{Binding CheckIn,  Mode=OneWay, StringFormat=dd.MM.yyyy}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding CheckOut, Mode=OneWay, StringFormat=dd.MM.yyyy}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding Nights,   Mode=OneWay}"/>
                                                <Run Text=" ночей)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="16" FontWeight="Bold"
                                                       Foreground="#1A3C5E" HorizontalAlignment="Right">
                                                <Run Text="{Binding TotalPrice, Mode=OneWay, StringFormat={}{0:N0}}"/>
                                                <Run Text=" ₽"/>
                                            </TextBlock>
                                            <TextBlock Text="✅ Подтверждено" FontSize="11"
                                                       Foreground="#2E7D32" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- СТРОКА СТАТУСА -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="6,0,6,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,12,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="160" Height="10"
                                 Foreground="#C9A84C" Background="#E2E8F0" BorderThickness="0"/>
                    <TextBlock Text=" Обработка запроса..." FontSize="12" FontStyle="Italic"
                               Foreground="#5A6A7E" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage, Mode=OneWay}"
                           FontSize="13" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>