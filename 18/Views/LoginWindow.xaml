<Window x:Class="HotelBooking.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grand Hotel — Вход в систему"
        Width="420" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F6FA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🏨" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="GRAND HOTEL" FontSize="22" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="Система управления" FontSize="12" Foreground="#BDC3C7"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="24" Background="White" CornerRadius="12" Padding="28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="3"/>
            </Border.Effect>
            <StackPanel x:Name="LoginPanel">
                <TextBlock x:Name="FormTitle" Text="Вход в систему" FontSize="18" FontWeight="Bold"
                           Foreground="#2C3E50" Margin="0,0,0,20"/>

                <TextBlock Text="Имя пользователя" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock x:Name="FullNameLabel" Text="Полное имя" Style="{StaticResource FieldLabel}"
                           Visibility="Collapsed"/>
                <TextBox x:Name="FullNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"
                         Visibility="Collapsed"/>

                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,20"/>

                <TextBlock x:Name="ErrorLabel" Foreground="#E74C3C" FontSize="12"
                           Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed"/>

                <Button x:Name="ActionButton" Content="Войти"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40" Click="ActionButton_Click"/>

                <Button x:Name="ToggleButton" Content="Нет аккаунта? Зарегистрироваться"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#3498DB" FontSize="12"
                        Margin="0,12,0,0" Cursor="Hand"
                        Click="ToggleButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
