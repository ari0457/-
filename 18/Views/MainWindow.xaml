<Window x:Class="HotelBooking.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HotelBooking.ViewModels"
        Title="Grand Hotel — Система управления"
        Width="1200" Height="780"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding BookRoomCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditBookingCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding CancelBookingCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1" Padding="4,2">
            <MenuItem Header="_Файл">
                <MenuItem Header="Обновить" Command="{Binding RefreshCommand}" InputGestureText="F5"/>
                <Separator/>
                <MenuItem Header="Выйти" Click="Logout_Click"/>
            </MenuItem>
            <MenuItem Header="_Номера">
                <MenuItem Header="Все номера" Click="ShowRooms_Click"/>
                <MenuItem Header="Доступные номера" Click="ShowAvailableRooms_Click"/>
            </MenuItem>
            <MenuItem Header="_Бронирование">
                <MenuItem Header="Забронировать (Ctrl+N)" Command="{Binding BookRoomCommand}"/>
                <MenuItem Header="Редактировать (Ctrl+E)" Command="{Binding EditBookingCommand}"/>
                <MenuItem Header="Отменить (Ctrl+D)" Command="{Binding CancelBookingCommand}"/>
            </MenuItem>
            <MenuItem Header="_Настройки" Click="ShowSettings_Click"/>
        </Menu>

        <Border DockPanel.Dock="Top" Background="White" Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <Button Content="➕ Забронировать" Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding BookRoomCommand}" Margin="0,0,8,0"
                            ToolTip="Забронировать номер (Ctrl+N)"/>
                    <Button Content="✏️ Редактировать" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding EditBookingCommand}" Margin="0,0,8,0"
                            ToolTip="Редактировать бронь (Ctrl+E)"/>
                    <Button Content="❌ Отменить бронь" Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding CancelBookingCommand}"
                            ToolTip="Отменить бронирование (Ctrl+D)"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,12,0"/>
                    <Button Content="Выйти" Click="Logout_Click"
                            Background="Transparent" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="10,6" FontSize="12" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#2C3E50" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="White" FontSize="12"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Foreground="#BDC3C7" FontSize="11" VerticalAlignment="Center">Ctrl+N: Бронь | Ctrl+E: Ред. | Ctrl+D: Отмена</TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="LoadingOverlay" Panel.ZIndex="99" Visibility="Collapsed">
            <Rectangle Fill="#80000000"/>
            <Border Background="White" CornerRadius="12" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="200">
                <StackPanel>
                    <TextBlock x:Name="LoadingText" Text="Загрузка..." FontSize="16"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Width="180"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="16,16,8,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="260"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="🏠" FontSize="22"/>
                            <TextBlock Text="{Binding Rooms.Count}" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock Text="Всего номеров" FontSize="11" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="✅" FontSize="22"/>
                            <TextBlock Text="{Binding AvailableRooms.Count}" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                            <TextBlock Text="Свободно" FontSize="11" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="📋" FontSize="22"/>
                            <TextBlock Text="{Binding Bookings.Count}" FontSize="24" FontWeight="Bold" Foreground="#3498DB"/>
                            <TextBlock Text="Бронирований" FontSize="11" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="🔄" FontSize="22"/>
                            <Button Content="Обновить" Command="{Binding RefreshCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Padding="8,4" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🏨 Номера отеля" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Rooms}"
                                  SelectedItem="{Binding SelectedRoom}"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="itemBorder" CornerRadius="8" Padding="12,10"
                                                        BorderThickness="1" BorderBrush="Transparent">
                                                    <ContentPresenter/>
                                                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="scaleTransform" ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="itemBorder" Property="Background" Value="#F0F7FF"/>
                                                        <Setter TargetName="itemBorder" Property="BorderBrush" Value="#BDE0FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="itemBorder" Property="Background" Value="#DBEAFE"/>
                                                        <Setter TargetName="itemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="10"
                                                Background="{Binding IsAvailable, Converter={StaticResource AvailabilityToColor}}"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Number}" Foreground="White"
                                                       FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" FontSize="13" Foreground="#2C3E50">
                                                <Run Text="Номер "/>
                                                <Run Text="{Binding Number}"/>
                                                <Run Text=" — "/>
                                                <Run Text="{Binding Type}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="#7F8C8D" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0"
                                                   FontSize="11" Foreground="#7F8C8D">
                                            <Run Text="👤 "/>
                                            <Run Text="{Binding Capacity}"/>
                                        </TextBlock>
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Width="110">
                                            <TextBlock Text="{Binding PricePerNight, Converter={StaticResource PriceConverter}}"
                                                       FontWeight="Bold" FontSize="14" Foreground="#2C3E50" HorizontalAlignment="Right"/>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" Margin="0,2,0,0"
                                                    Background="{Binding IsAvailable, Converter={StaticResource AvailabilityToColor}}">
                                                <TextBlock Text="{Binding IsAvailable, Converter={StaticResource AvailabilityToText}}"
                                                           Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📋 Активные бронирования" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Bookings}"
                                  SelectedItem="{Binding SelectedBooking}"
                                  Style="{StaticResource ModernDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="45"/>
                                <DataGridTextColumn Header="Номер" Binding="{Binding Room.Number}" Width="65"/>
                                <DataGridTextColumn Header="Клиент" Binding="{Binding Client.FullName}" Width="*"/>
                                <DataGridTextColumn Header="Заезд" Binding="{Binding CheckIn, StringFormat=dd.MM.yyyy}" Width="90"/>
                                <DataGridTextColumn Header="Выезд" Binding="{Binding CheckOut, StringFormat=dd.MM.yyyy}" Width="90"/>
                                <DataGridTextColumn Header="Ночей" Binding="{Binding Nights}" Width="60"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat={}{0:N0} ₽}" Width="90"/>
                                <DataGridTemplateColumn Header="Статус" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" Margin="2"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1" Margin="8,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="📊 Детали номера" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                        <StackPanel Visibility="{Binding SelectedRoom, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}">
                            <TextBlock Text="Выберите номер для просмотра деталей"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0,16"/>
                        </StackPanel>

                        <StackPanel Visibility="{Binding SelectedRoom, Converter={StaticResource NullToVisibility}}">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#2C3E50">
                                        <Run Text="Номер "/>
                                        <Run Text="{Binding SelectedRoom.Number, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedRoom.Type, Mode=OneWay}"
                                               FontSize="13" Foreground="#7F8C8D"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="6" Padding="8,4"
                                        Background="{Binding SelectedRoom.IsAvailable, Converter={StaticResource AvailabilityToColor}, Mode=OneWay}">
                                    <TextBlock Text="{Binding SelectedRoom.IsAvailable, Converter={StaticResource AvailabilityToText}, Mode=OneWay}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding SelectedRoom.Description, Mode=OneWay}"
                                       FontSize="12" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Цена/ночь" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text="{Binding SelectedRoom.PricePerNight, Converter={StaticResource PriceConverter}, Mode=OneWay}"
                                               FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Вместимость" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#2C3E50">
                                        <Run Text="{Binding SelectedRoom.Capacity, Mode=OneWay}"/>
                                        <Run Text=" чел."/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <Button Content="➕ Забронировать этот номер"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding BookRoomCommand}"
                                    Margin="0,12,0,0" Height="36"
                                    IsEnabled="{Binding SelectedRoom.IsAvailable, Mode=OneWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="💬 Чат с клиентами" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChatPanel"/>
                        </ScrollViewer>
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChatInput" Grid.Column="0"
                                     Style="{StaticResource ModernTextBox}"
                                     Padding="8,6" FontSize="12"
                                     KeyDown="ChatInput_KeyDown"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="➤" Width="36" Height="36"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SendChat_Click" Padding="0"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
