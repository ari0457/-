@model Contact
@{
    ViewData["Title"] = "Редактировать контакт";
}

<div class="form-page">
    <div class="form-header">
        <a href="/" class="back-link">← Назад</a>
        <h2>Редактировать контакт</h2>
    </div>

    <form asp-action="Edit" method="post" class="contact-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="field">
            <label asp-for="Name"></label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" class="error"></span>
        </div>

        <div class="field">
            <label asp-for="Phone"></label>
            <input asp-for="Phone" />
            <span asp-validation-for="Phone" class="error"></span>
        </div>

        <div class="field">
            <label asp-for="Email"></label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="error"></span>
        </div>

        <div class="field">
            <label asp-for="Note"></label>
            <textarea asp-for="Note" rows="3"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Сохранить</button>
            <a href="/" class="btn-secondary">Отмена</a>
        </div>
    </form>
</div>
