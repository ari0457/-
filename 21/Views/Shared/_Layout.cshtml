<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PhoneBook</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <a class="logo" href="/">
            <span class="logo-icon">📒</span>
            <span>PhoneBook</span>
        </a>
        <a class="btn-add" href="/Contacts/Create">+ Добавить</a>
    </header>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="toast">@TempData["Success"]</div>
        }
        @RenderBody()
    </main>
</body>
</html>
