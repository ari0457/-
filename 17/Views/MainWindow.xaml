<Window x:Class="HotelAnimatedApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HotelAnimatedApp.ViewModels"
        Title="🏨 Grand Palace Hotel" Height="750" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#0F1923">

    <Window.DataContext>
        <vm:HotelViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Кнопка Забронировать с анимацией нажатия -->
        <Style x:Key="BookBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2E7D32"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="24,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <!-- Нажатие — сжать -->
                            <EventTrigger RoutedEvent="PreviewMouseDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                            To="0.94" Duration="0:0:0.08"/>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                            To="0.94" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <!-- Отпустить — вернуть -->
                            <EventTrigger RoutedEvent="PreviewMouseUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                            To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                            To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка Отменить -->
        <Style x:Key="CancelBtn" TargetType="Button" BasedOn="{StaticResource BookBtn}">
            <Setter Property="Background" Value="#C62828"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox тёмный -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#1A2A3A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="CaretBrush"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#2A4A6A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>

        <!-- DatePicker тёмный -->
        <Style x:Key="DarkDate" TargetType="DatePicker">
            <Setter Property="Background"      Value="#1A2A3A"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#2A4A6A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ ШАПКА ══ -->
        <Border Grid.Row="0" Background="#0D1F2D" Padding="28,18">
            <Grid x:Name="HeaderGrid" Opacity="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏨" FontSize="36"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Grand Palace Hotel"
                                   FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Система бронирования номеров"
                                   FontSize="12" Foreground="#5A8AAA"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ ОСНОВНАЯ ОБЛАСТЬ ══ -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ── ЛЕВАЯ ЧАСТЬ: сетка номеров ── -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock DockPanel.Dock="Top"
                           Text="🛏 Доступные номера"
                           FontSize="16" FontWeight="Bold"
                           Foreground="White" Margin="8,0,0,12"/>

                <ItemsControl x:Name="RoomsControl"
                              ItemsSource="{Binding Rooms}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Height="190"
                                    Opacity="0"
                                    Loaded="RoomCard_Loaded"
                                    Margin="8">
                                <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"      Value="#1A2A3A"/>
                                        <Setter Property="CornerRadius"    Value="14"/>
                                        <Setter Property="BorderBrush"     Value="#2E7D32"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="Cursor"          Value="Hand"/>
                                        <Setter Property="Padding"         Value="16"/>
                                        <Style.Triggers>
                                            <!-- Занятый номер -->
                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                <Setter Property="BorderBrush" Value="#C62828"/>
                                                <Setter Property="Background"  Value="#1F1515"/>
                                            </DataTrigger>
                                            <!-- Выбранный номер -->
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush"     Value="#C9A84C"/>
                                                <Setter Property="BorderThickness" Value="3"/>
                                                <Setter Property="Background"      Value="#1A1800"/>
                                            </DataTrigger>
                                            <!-- Hover — масштаб через триггер -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                To="1.05" Duration="0:0:0.15"/>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                To="1.05" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                To="1" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectRoomCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ImageIcon, Mode=OneWay}"
                                                   FontSize="28" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Top">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="✅ Свободен"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                            <Setter Property="Text"       Value="🔴 Занят"/>
                                                            <Setter Property="Foreground" Value="#EF5350"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="White">
                                        <Run Text="№"/>
                                        <Run Text="{Binding RoomNumber, Mode=OneWay}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding RoomType, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Text="{Binding Description, Mode=OneWay}"
                                               FontSize="11" Foreground="#7A9AB0"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>

                                    <TextBlock Margin="0,8,0,0" FontWeight="Bold">
                                        <Run Foreground="#C9A84C" FontSize="18"
                                             Text="{Binding PricePerNight, Mode=OneWay,
                                                    StringFormat={}{0:N0}}"/>
                                        <Run Foreground="#5A8AAA" FontSize="12" Text=" ₽/ночь"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>

            <!-- ── ПРАВАЯ ЧАСТЬ: детали + форма ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Панель деталей выбранного номера -->
                <Border Grid.Row="0"
                        x:Name="DetailPanel"
                        Background="#0D1F2D"
                        CornerRadius="14"
                        Padding="20"
                        Margin="0,0,0,12"
                        Opacity="0"
                        Visibility="{Binding HasSelectedRoom,
                                     Converter={StaticResource BoolToVis}}">
                    <Border.RenderTransform>
                        <TranslateTransform X="0"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="📋 Выбранный номер"
                                   FontSize="13" Foreground="#5A8AAA" Margin="0,0,0,10"/>
                        <TextBlock FontSize="20" FontWeight="Bold" Foreground="White">
                            <Run Text="{Binding SelectedRoom.ImageIcon, Mode=OneWay}"/>
                            <Run Text=" №"/>
                            <Run Text="{Binding SelectedRoom.RoomNumber, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SelectedRoom.RoomType, Mode=OneWay}"
                                   FontSize="14" Foreground="#C9A84C" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SelectedRoom.Description, Mode=OneWay}"
                                   FontSize="12" Foreground="#7A9AB0"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>
                        <TextBlock Margin="0,10,0,0" FontWeight="Bold">
                            <Run Foreground="#C9A84C" FontSize="22"
                                 Text="{Binding SelectedRoom.PricePerNight, Mode=OneWay,
                                        StringFormat={}{0:N0}}"/>
                            <Run Foreground="#5A8AAA" FontSize="13" Text=" ₽/ночь"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Форма бронирования -->
                <Border Grid.Row="1"
                        x:Name="FormBorder"
                        Background="#0D1F2D"
                        CornerRadius="14"
                        Padding="20"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="🛎 Новое бронирование"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,16"/>

                        <TextBlock Text="ФИО гостя:"
                                   FontSize="12" Foreground="#5A8AAA" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding GuestName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkInput}"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="Заезд:" FontSize="12"
                                           Foreground="#5A8AAA" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding CheckIn}"
                                            Style="{StaticResource DarkDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="Выезд:" FontSize="12"
                                           Foreground="#5A8AAA" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding CheckOut}"
                                            Style="{StaticResource DarkDate}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Ошибка валидации -->
                        <Border Background="#3A1A00" CornerRadius="8"
                                Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding HasError,
                                             Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ValidationError, Mode=OneWay}"
                                       Foreground="#FF9800" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="🛎 Забронировать"
                                Command="{Binding BookCommand}"
                                Style="{StaticResource BookBtn}"
                                Margin="0,0,0,16"/>

                        <!-- Список бронирований -->
                        <TextBlock Text="📂 Активные брони"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,8"/>

                        <TextBlock Text="Нет активных бронирований."
                                   FontSize="12" Foreground="#5A8AAA"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Bookings.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ListView ItemsSource="{Binding Bookings}"
                                  SelectedItem="{Binding SelectedBooking}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  MaxHeight="200"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding"    Value="0"/>
                                    <Setter Property="Margin"     Value="0,0,0,6"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="ItemBd"
                                                        Background="#1A2A3A"
                                                        CornerRadius="10"
                                                        Padding="12,8">
                                                    <ContentPresenter/>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="SelectionStates">
                                                            <VisualState x:Name="Selected">
                                                                <Storyboard>
                                                                    <ColorAnimation
                                                                        Storyboard.TargetName="ItemBd"
                                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                        To="#1A3A1A"
                                                                        Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Unselected"/>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold"
                                                       Foreground="White" FontSize="13">
                                                <Run Text="Бронь #"/>
                                                <Run Text="{Binding Id, Mode=OneWay}"/>
                                                <Run Foreground="#C9A84C" Text=" · №"/>
                                                <Run Foreground="#C9A84C"
                                                     Text="{Binding RoomNumber, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="#7A9AB0"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       Text="{Binding GuestName, Mode=OneWay}"/>
                                            <TextBlock Foreground="#5A8AAA"
                                                       FontSize="10" Margin="0,1,0,0">
                                                <Run Text="{Binding CheckIn,  Mode=OneWay,
                                                            StringFormat=dd.MM.yyyy}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding CheckOut, Mode=OneWay,
                                                            StringFormat=dd.MM.yyyy}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding Nights, Mode=OneWay}"/>
                                                <Run Text="н)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#C9A84C">
                                            <Run Text="{Binding TotalPrice, Mode=OneWay,
                                                        StringFormat={}{0:N0}}"/>
                                            <Run Text=" ₽"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button Content="🗑 Отменить бронирование"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource CancelBtn}"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ СТРОКА СТАТУСА ══ -->
        <Border Grid.Row="2"
                x:Name="StatusBar"
                Background="#0D1F2D"
                Padding="24,12"
                Opacity="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Индикатор загрузки -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,16,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True"
                                 Width="140" Height="6"
                                 Foreground="#C9A84C"
                                 Background="#1A2A3A"
                                 BorderThickness="0"/>
                    <TextBlock Text=" Обработка..." FontSize="12"
                               Foreground="#5A8AAA"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage, Mode=OneWay}"
                           FontSize="13" Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>